# Choose which provider the backend should use: "google" or "microsoft"
TRANSLATION_PROVIDER=google

# ---- Google Cloud Translation ----
# Create a key at: https://console.cloud.google.com/apis/credentials
# Enable the "Cloud Translation API" on your project first.
GOOGLE_TRANSLATE_API_KEY=your_google_api_key_here

# ---- Microsoft Translator (Azure Cognitive Services) ----
# Create a resource at: https://portal.azure.com (Translator resource)
# Key is found under "Keys and Endpoint" in the resource.
MICROSOFT_TRANSLATOR_KEY=your_microsoft_key_here
MICROSOFT_TRANSLATOR_REGION=your_resource_region_here
MICROSOFT_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# ---- Server ----
PORT=3000

# Comma-separated list of origins allowed to call this API.
# Use * only for local testing, never in production.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
